#include <stdio.h>
int main() {
    int num, i, n=0;
    printf("Enter a number:");
    scanf("%d", &num);
    if (num<=1){
        printf("not a prime number");
    }
    else{
        for(i=2; i<num/2; i++)
        {
            if(num%i==0)
            {
                n=1;
                break;
            }
        }
        if (n==0)
        printf("prime number");
        else
        printf("not a prime number");
    }
    return 0;

}
