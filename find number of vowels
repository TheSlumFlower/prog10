#include <stdio.h>
int main(){
    int len=0, i, count=0;
    char a[50];

    printf("Enter a string:");
    fgets(a,sizeof(a),stdin);

    while(a[len]!= '\0'){
        len++;
    }
    for(i=0; i<=len; i++){
        if(a[i]=='a' || a[i]=='e' ||a[i]=='i' ||a[i]=='o' ||a[i]=='u'  ||a[i]=='A' ||a[i]=='E' ||a[i]=='I' ||a[i]=='O' ||a[i]=='U'){
            count++ ;

        }

    }
    printf("The no. of  vowels are %d", count);

    return 0;
}
